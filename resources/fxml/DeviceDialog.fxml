<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="550.0" prefWidth="380.0" styleClass="dialog-pane" stylesheets="@../style.css" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.techfix.controller.DeviceDialogController">
   <children>
      <VBox alignment="CENTER" spacing="15.0" AnchorPane.bottomAnchor="20.0" AnchorPane.leftAnchor="30.0" AnchorPane.rightAnchor="30.0" AnchorPane.topAnchor="20.0">
         <children>
            <Label text="Add New Device" textFill="#0f172a">
               <font>
                  <Font name="System Bold" size="22.0" />
               </font>
               <VBox.margin>
                  <Insets bottom="10.0" />
               </VBox.margin>
            </Label>
            
            <VBox spacing="5.0">
               <Label text="Customer Phone:" textFill="#64748b">
                  <font><Font name="System Bold" size="14.0" /></font>
               </Label>
               <TextField fx:id="customerPhoneField" editable="false" prefHeight="35.0" styleClass="dialog-input" />
            </VBox>
            <ComboBox fx:id="brandComboBox" prefWidth="350.0" promptText="Brand" styleClass="dialog-combo-box" />
            <ComboBox fx:id="typeComboBox" prefWidth="350.0" promptText="Device Type" styleClass="dialog-combo-box" />
            <TextField fx:id="modelField" prefHeight="35.0" promptText="Model" styleClass="dialog-input" />
            <TextField fx:id="colorField" prefHeight="35.0" promptText="Color" styleClass="dialog-input" />
            <TextField fx:id="serialNumberField" prefHeight="35.0" promptText="Serial Number (IMEI / SN)" styleClass="dialog-input">
               <VBox.margin>
                  <Insets bottom="30.0" />
               </VBox.margin></TextField>

            <HBox alignment="CENTER" spacing="15.0">
               <children>
                  <Button mnemonicParsing="false" onAction="#handleSave" prefHeight="38.0" prefWidth="125.0" styleClass="btn-save" text="Save Device">
                     <HBox.margin>
                        <Insets right="20.0" />
                     </HBox.margin></Button>
                  <Button mnemonicParsing="false" onAction="#handleCancel" prefHeight="38.0" prefWidth="125.0" styleClass="btn-cancel" text="Cancel" />
               </children>
               <VBox.margin>
                  <Insets top="10.0" />
               </VBox.margin>
            </HBox>
         </children>
      </VBox>
   </children>
</AnchorPane>
