<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox prefHeight="450.0" prefWidth="550.0" spacing="10.0" style="-fx-background-color: #f8fafc; -fx-padding: 20;" xmlns="http://javafx.com/javafx/19" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.techfix.controller.FinishJobController">
   <children>
      <Label style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: #1e293b;" text="Finish Repair &amp; Add Items" />
      <Separator prefWidth="200.0" />
      
      <HBox alignment="CENTER_LEFT" spacing="10.0">
         <children>
            <VBox HBox.hgrow="ALWAYS">
               <children>
                  <Label text="Select Part / Service:" textFill="#475569">
                     <font><Font name="System Bold" size="12.0" /></font></Label>
                  <ComboBox fx:id="itemComboBox" maxWidth="1.7976931348623157E308" promptText="Choose item..." />
               </children>
            </VBox>
            <VBox prefWidth="80.0">
               <children>
                  <Label text="Qty / Hrs:" textFill="#475569">
                     <font><Font name="System Bold" size="12.0" /></font></Label>
                  <TextField fx:id="qtyField" promptText="e.g. 1" />
               </children>
            </VBox>
            <VBox alignment="BOTTOM_CENTER">
               <children>
                  <Button mnemonicParsing="false" onAction="#handleAddItem" style="-fx-background-color: #10b981; -fx-text-fill: white; -fx-font-weight: bold;" text="Add" />
               </children>
            </VBox>
         </children>
      </HBox>
      
      <TableView fx:id="cartTable" prefHeight="200.0" prefWidth="200.0" VBox.vgrow="ALWAYS">
        <columns>
          <TableColumn fx:id="colName" prefWidth="220.0" text="Item Name" />
          <TableColumn fx:id="colType" prefWidth="90.0" text="Type" />
            <TableColumn fx:id="colPrice" prefWidth="70.0" text="Price" />
            <TableColumn fx:id="colQty" prefWidth="60.0" text="Qty" />
            <TableColumn fx:id="colTotal" prefWidth="70.0" text="Total" />
        </columns>
      </TableView>
      
      <HBox alignment="CENTER_LEFT">
         <children>
            <Label text="Total Cost: " textFill="#1e293b">
               <font><Font name="System Bold" size="18.0" /></font>
            </Label>
            <Label fx:id="totalCostLabel" text="\$0.00" textFill="#ef4444">
               <font><Font name="System Bold" size="18.0" /></font>
            </Label>
            <Region HBox.hgrow="ALWAYS" />
            <Button mnemonicParsing="false" onAction="#handleCompleteJob" style="-fx-background-color: #3b82f6; -fx-text-fill: white; -fx-font-weight: bold; -fx-padding: 8 20;" text="Confirm &amp; Complete Job" />
         </children>
         <VBox.margin>
            <Insets top="10.0" />
         </VBox.margin>
      </HBox>
   </children>
</VBox>