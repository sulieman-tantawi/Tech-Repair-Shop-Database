<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox prefWidth="420.0" spacing="12.0" style="-fx-background-color: #f1f5f9; -fx-padding: 20;" xmlns="http://javafx.com/javafx/19" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.techfix.controller.CreateJobController">
   <children>
      <Label style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #1e293b;" text="Create Repair Job" />
      <Separator prefWidth="200.0" />
      
      <Label style="-fx-font-weight: bold; -fx-text-fill: #475569;" text="Customer Name:" />
      <TextField fx:id="txtCustomerName" editable="false" style="-fx-background-color: #e2e8f0; -fx-font-size: 14px;" />
      
      <Label style="-fx-font-weight: bold; -fx-text-fill: #475569;" text="Select Device:" />
      <ComboBox fx:id="comboDevice" maxWidth="1.7976931348623157E308" promptText="-- Choose a device --" style="-fx-font-size: 14px;" />
      
      <Label style="-fx-font-weight: bold; -fx-text-fill: #475569;" text="Assign Technician:" />
      <ComboBox fx:id="comboTech" maxWidth="1.7976931348623157E308" promptText="-- Choose a technician --" style="-fx-font-size: 14px;" />
      
      <Label style="-fx-font-weight: bold; -fx-text-fill: #475569;" text="Problem Description:" />
      <TextArea fx:id="txtProblem" prefRowCount="3" promptText="Write the issue the customer is facing..." style="-fx-font-size: 14px;" wrapText="true" />
      
      <HBox alignment="CENTER_RIGHT" spacing="10.0">
         <children>
            <Button mnemonicParsing="false" onAction="#handleCancel" style="-fx-background-color: #ef4444; -fx-text-fill: white; -fx-font-weight: bold; -fx-padding: 8 20;" text="Cancel" />
            <Button mnemonicParsing="false" onAction="#handleCreate" style="-fx-background-color: #3b82f6; -fx-text-fill: white; -fx-font-weight: bold; -fx-padding: 8 20;" text="Create Job" />
         </children>
         <VBox.margin>
            <Insets top="10.0" />
         </VBox.margin>
      </HBox>
   </children>
</VBox>